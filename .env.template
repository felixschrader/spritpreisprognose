# =============================================================================
# .env.template
# Vorlage für Umgebungsvariablen — Kopieren als .env und Werte eintragen
#
# WICHTIG: .env niemals committen! Sie enthält geheime API-Keys.
#          .env ist in .gitignore eingetragen.
#
# Kopieren:
#   cp .env.template .env
# =============================================================================

# Tankerkönig API
# Registrierung: https://creativecommons.tankerkoenig.de/
TANKERKOENIG_USER=deine@email.de
TANKERKOENIG_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Slack Webhook für GitHub Actions Benachrichtigungen
# Einrichten: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx